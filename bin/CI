#!/usr/bin/env bash
set -e
set -o pipefail
trap 'exit 130' INT

ACTION_YML="${BAO_BASE_DIR}/.github/actions/test-foundry/action.yml"
STATE_FILE="${PWD}/tmp/.ci-state"

debug=0
continue_mode=0
for arg in "$@"; do
    case "$arg" in
        --debug|-d) debug=1 ;;
        --continue) continue_mode=1 ;;
        *) echo "ERROR: unknown argument: $arg" >&2; exit 1 ;;
    esac
done

if [[ "$continue_mode" == "0" ]]; then
    rm -f "$STATE_FILE"
fi

# Phase 1: parse action.yml — build execute[] and skipped[] lists
execute=()
skipped=()
marker_seen=0

while IFS= read -r line; do
    cmd="${line#"${line%%[![:space:]]*}"}"

    if [[ "$marker_seen" == "1" ]]; then
        if [[ -z "$cmd" ]]; then
            echo "ERROR: blank line after '# ci-execute-next-line' in $ACTION_YML" >&2
            exit 1
        elif [[ "$cmd" != yarn\ * ]]; then
            echo "ERROR: '# ci-execute-next-line' not followed by a yarn command (got: $cmd)" >&2
            exit 1
        fi
        execute+=("$cmd")
        marker_seen=0
        continue
    fi

    if [[ "$cmd" == "# ci-execute-next-line" ]]; then
        marker_seen=1
    elif [[ "$cmd" == yarn\ * ]]; then
        skipped+=("$cmd")
    fi
done < "$ACTION_YML"

if [[ "$marker_seen" == "1" ]]; then
    echo "ERROR: '# ci-execute-next-line' at end of file with no following command" >&2
    exit 1
fi

total=${#execute[@]}

# Determine starting step (0-based index)
start_index=0
if [[ "$continue_mode" == "1" ]]; then
    if [[ ! -f "$STATE_FILE" ]]; then
        echo "ERROR: no .ci-state file found — run 'yarn CI' first" >&2
        exit 1
    fi
    start_index=$(cat "$STATE_FILE")
    echo "Resuming from step $((start_index + 1)) of $total: ${execute[$start_index]}"
fi

# Phase 2: execute (or print in debug mode)
for ((i = start_index; i < total; i++)); do
    cmd="${execute[$i]}"
    echo ""
    echo "=== [$((i + 1))/$total] $cmd ==="
    if [[ "$debug" == "1" ]]; then
        echo "[debug] skipping execution"
    else
        if ! eval "$cmd"; then
            echo "" >&2
            echo "=== FAILED at step $((i + 1))/$total: $cmd ===" >&2
            mkdir -p "$(dirname "$STATE_FILE")"
            echo "$i" > "$STATE_FILE"
            echo "Run 'yarn CI --continue' to resume from this step." >&2
            exit 1
        fi
    fi
done

rm -f "$STATE_FILE"

if [[ ${#skipped[@]} -gt 0 ]]; then
    echo ""
    echo "=== yarn commands not executed (add '# ci-execute-next-line' above to run) ==="
    for cmd in "${skipped[@]}"; do
        echo "  $cmd"
    done
fi
