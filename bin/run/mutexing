#!/bin/bash

# Function to perform double-checked locking around any operation
# Usage: with_lock "lock_name" "complete_flag_path" function_name [args...]
# Call with_lock with:
# A unique lock name
# Path to a flag file indicating completion
# The name of your function
# Any arguments to pass to your function

# Example usage:
# Define your installation function
# install_something() {
#   echo "Installing software package: $1"
#   # Your installation commands here
#   sleep 5  # Simulate work
#   echo "Installed $1"
#   return 0
# }

# update_config() {
#   echo "Updating configuration for: $1"
#   # Your configuration update commands here
#   sleep 3  # Simulate work
#   echo "Updated configuration for $1"
#   return 0
# }

# Use the with_lock function to wrap your operations
# with_lock "install-nginx" "/usr/local/share/nginx_installed" install_something "nginx"
# with_lock "update-config" "/etc/app/config_updated" update_config "myapp"

with_mutex() {
  local LOCK_NAME="$1"
  local COMPLETE_FLAG="$2"
  local FUNCTION="$3"
  shift 3  # Remove the first three arguments, leaving any remaining args for the function

  local LOCK_FILE="/tmp/${LOCK_NAME}.lock"
  local LOCK_HOLDER="/tmp/${LOCK_NAME}.holder"

  # Function to clean up lock if script terminates abnormally
  cleanup_lock() {
    if [ -f "$LOCK_HOLDER" ] && [ "$(cat "$LOCK_HOLDER")" = "$$" ]; then
      rm -f "$LOCK_HOLDER"
    fi
  }

  # Set trap for this subshell
  trap cleanup_lock EXIT INT TERM

  # First check - see if operation is already complete
  if [ -f "$COMPLETE_FLAG" ]; then
    echo "Operation '$LOCK_NAME' is already complete."
    return 0
  fi

  # Try to acquire lock
  (
    flock -n 9 || exit 1
    echo $$ > "$LOCK_HOLDER"
  ) 9>"$LOCK_FILE"

  # Check if we got the lock
  if [ ! -f "$LOCK_HOLDER" ] || [ "$(cat "$LOCK_HOLDER")" != "$$" ]; then
    echo "Another process is performing operation '$LOCK_NAME'. Waiting..."

    # Wait for other process to complete
    while [ ! -f "$COMPLETE_FLAG" ] && [ -f "$LOCK_HOLDER" ]; do
      sleep 1
    done

    # Second check - see if now complete
    if [ -f "$COMPLETE_FLAG" ]; then
      echo "Operation '$LOCK_NAME' was completed by another process."
      return 0
    fi

    # If we reach here, the other process failed or disappeared
    # Try to acquire lock again
    (
      flock -n 9 || exit 1
      echo $$ > "$LOCK_HOLDER"
    ) 9>"$LOCK_FILE"

    # Make sure we got the lock this time
    if [ ! -f "$LOCK_HOLDER" ] || [ "$(cat "$LOCK_HOLDER")" != "$$" ]; then
      echo "Failed to acquire lock for '$LOCK_NAME'. Exiting."
      return 1
    fi
  fi

  # Double-check again before performing operation
  if [ -f "$COMPLETE_FLAG" ]; then
    echo "Operation '$LOCK_NAME' is already complete (double-check)."
    cleanup_lock
    return 0
  fi

  echo "Performing operation '$LOCK_NAME'..."

  # Call the function with remaining arguments
  "$FUNCTION" "$@"
  local RESULT=$?

  if [ $RESULT -eq 0 ]; then
    # Mark operation as complete
    touch "$COMPLETE_FLAG"
    echo "Operation '$LOCK_NAME' completed successfully."
  else
    echo "Operation '$LOCK_NAME' failed with exit code $RESULT."
  fi

  cleanup_lock
  return $RESULT
}

export -f with_mutex
