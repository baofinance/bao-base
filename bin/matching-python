#!/usr/bin/env bash
set -euo pipefail

# Parse command line arguments
PYPROJECT_PATH=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --pyproject=*)
            PYPROJECT_PATH="${1#*=}"
            shift
            ;;
        --pyproject)
            PYPROJECT_PATH="$2"
            shift 2
            ;;
        *)
            error "Unknown argument: $1"
            exit 1
            ;;
    esac
done

# Ensure pyproject path is provided
if [[ -z "$PYPROJECT_PATH" ]]; then
    error "Required argument --pyproject not provided"
    exit 1
fi

debug "matching-python"
debug "with args pyproject=$PYPROJECT_PATH"

# Extract Python version constraint from pyproject.toml using Poetry
get_constraint() {
    local pyproject_path="$1"
    debug "get_constraint($pyproject_path)"

    if [[ ! -f "$pyproject_path" ]]; then
        error "pyproject.toml not found at $pyproject_path"
        exit 1
    fi

    # Use Poetry to show the dependencies, which will correctly parse the file
    local poetry_output
    poetry_output=$(poetry --directory="$(dirname "$pyproject_path")" show --tree 2>/dev/null || true)

    # Extract Python version constraint from Poetry's output
    if [[ "$poetry_output" == *"requires the following packages"* ]]; then
        local python_constraint
        python_constraint=$(echo "$poetry_output" | grep -E "python[[:space:]]+([^[:space:]]+)" | head -1 | sed -E 's/python[[:space:]]+([^[:space:]]+).*/\1/')

        if [[ -n "$python_constraint" ]]; then
            debug "Found Python constraint from Poetry: $python_constraint"
            echo "$python_constraint"
            return 0
        fi
    fi


    debug "No Python constraint found"
    echo ""
}

# Convert caret syntax to PEP440 version ranges
to_pep440() {
    local constraint="$1"
    debug "to_pep440($constraint)"

    # Handle caret syntax (^x.y.z)
    if [[ "$constraint" =~ ^\^([0-9]+)(\.([0-9]+))?(\.([0-9]+))? ]]; then
        local major="${BASH_REMATCH[1]}"
        local minor="${BASH_REMATCH[3]:-}"
        local patch="${BASH_REMATCH[5]:-}"

        if [[ "$major" == "0" ]]; then
            if [[ -z "$minor" ]]; then
                echo "<1.0.0"
            elif [[ -z "$patch" ]]; then
                echo ">=0.$minor.0,<0.$((minor+1)).0"
            else
                echo ">=0.$minor.$patch,<0.$((minor+1)).0"
            fi
        else
            if [[ -z "$minor" ]]; then
                echo ">=$major.0.0,<$((major+1)).0.0"
            elif [[ -z "$patch" ]]; then
                echo ">=$major.$minor.0,<$((major+1)).0.0"
            else
                echo ">=$major.$minor.$patch,<$((major+1)).0.0"
            fi
        fi
    else
        # Return unchanged for other formats
        echo "$constraint"
    fi
}

# Compare version strings
version_compare() {
    local v1="$1"
    local op="$2"
    local v2="$3"

    # Split versions into components
    IFS='.' read -r -a v1_parts <<< "$v1"
    IFS='.' read -r -a v2_parts <<< "$v2"

    # Ensure both arrays have at least 3 elements
    while [[ ${#v1_parts[@]} -lt 3 ]]; do v1_parts+=("0"); done
    while [[ ${#v2_parts[@]} -lt 3 ]]; do v2_parts+=("0"); done

    local major1="${v1_parts[0]}"
    local minor1="${v1_parts[1]}"
    local patch1="${v1_parts[2]}"

    local major2="${v2_parts[0]}"
    local minor2="${v2_parts[1]}"
    local patch2="${v2_parts[2]}"

    # Compare versions
    case "$op" in
        "==")
            [[ "$major1" -eq "$major2" && "$minor1" -eq "$minor2" && "$patch1" -eq "$patch2" ]]
            ;;
        "!=")
            [[ "$major1" -ne "$major2" || "$minor1" -ne "$minor2" || "$patch1" -ne "$patch2" ]]
            ;;
        ">")
            if [[ "$major1" -gt "$major2" ]]; then
                return 0
            elif [[ "$major1" -eq "$major2" && "$minor1" -gt "$minor2" ]]; then
                return 0
            elif [[ "$major1" -eq "$major2" && "$minor1" -eq "$minor2" && "$patch1" -gt "$patch2" ]]; then
                return 0
            else
                return 1
            fi
            ;;
        ">=")
            if [[ "$major1" -gt "$major2" ]]; then
                return 0
            elif [[ "$major1" -eq "$major2" && "$minor1" -gt "$minor2" ]]; then
                return 0
            elif [[ "$major1" -eq "$major2" && "$minor1" -eq "$minor2" && "$patch1" -ge "$patch2" ]]; then
                return 0
            else
                return 1
            fi
            ;;
        "<")
            if [[ "$major1" -lt "$major2" ]]; then
                return 0
            elif [[ "$major1" -eq "$major2" && "$minor1" -lt "$minor2" ]]; then
                return 0
            elif [[ "$major1" -eq "$major2" && "$minor1" -eq "$minor2" && "$patch1" -lt "$patch2" ]]; then
                return 0
            else
                return 1
            fi
            ;;
        "<=")
            if [[ "$major1" -lt "$major2" ]]; then
                return 0
            elif [[ "$major1" -eq "$major2" && "$minor1" -lt "$minor2" ]]; then
                return 0
            elif [[ "$major1" -eq "$major2" && "$minor1" -eq "$minor2" && "$patch1" -le "$patch2" ]]; then
                return 0
            else
                return 1
            fi
            ;;
        *)
            error "Unsupported operator: $op"
            return 1
            ;;
    esac
}

# Check if version matches constraint
version_matches_constraint() {
    local version="$1"
    local constraint="$2"

    # Handle exact version match (==x.y.z)
    if [[ "$constraint" =~ ^==([0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
        local exact_version="${BASH_REMATCH[1]}"
        version_compare "$version" "==" "$exact_version"
        return $?
    fi

    # Handle version ranges (>=x.y.z,<x.y.z)
    if [[ "$constraint" =~ ([><]=?[0-9]+\.[0-9]+\.[0-9]+),([><]=?[0-9]+\.[0-9]+\.[0-9]+) ]]; then
        local range1="${BASH_REMATCH[1]}"
        local range2="${BASH_REMATCH[2]}"

        local op1="${range1//[0-9.]/}"
        local ver1="${range1#$op1}"

        local op2="${range2//[0-9.]/}"
        local ver2="${range2#$op2}"

        version_compare "$version" "$op1" "$ver1" && version_compare "$version" "$op2" "$ver2"
        return $?
    fi

    # Handle simple comparisons (>x.y.z, <x.y.z, etc.)
    if [[ "$constraint" =~ ^([><]=?)([0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
        local op="${BASH_REMATCH[1]}"
        local ver="${BASH_REMATCH[2]}"

        version_compare "$version" "$op" "$ver"
        return $?
    fi

    # Default case - no match
    return 1
}

# Check if current Python version matches constraint using Poetry
current_is_good() {
    local constraint="$1"
    local pyproject_dir="$2"

    debug "Checking if current Python version matches constraint: $constraint"

    # Try using Poetry directly to check compatibility
    if (cd "$pyproject_dir" && poetry check 2>/dev/null); then
        local current_py_version
        current_py_version=$(python3 --version 2>&1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')
        debug "Current Python $current_py_version is compatible"
        echo "$current_py_version"
        return 0
    fi

    # If Poetry check failed, fall back to manual version checking
    if ! command -v python3 &> /dev/null; then
        debug "Python 3 not found"
        return 1
    fi

    local version_output=$(python3 --version 2>&1)
    debug "current python=$version_output"

    if [[ "$version_output" =~ ([0-9]+\.[0-9]+\.[0-9]+) ]]; then
        local current_version="${BASH_REMATCH[1]}"

        if version_matches_constraint "$current_version" "$constraint"; then
            debug "current version $current_version is good"
            echo "$current_version"
            return 0
        else
            debug "current version $current_version does not match constraint"
            return 1
        fi
    else
        debug "Could not extract version from: $version_output"
        return 1
    fi
}

# Ensure pyenv is installed
ensure_pyenv_installed() {
    # Check if pyenv is in PATH
    if command -v pyenv &> /dev/null; then
        debug "Using system pyenv at $(which pyenv)"
        echo "pyenv"
        return 0
    fi

    # Check if pyenv exists at the default location
    local pyenv_bin="$HOME/.pyenv/bin/pyenv"
    if [[ -x "$pyenv_bin" ]]; then
        debug "Found pyenv at $pyenv_bin"
        echo "$pyenv_bin"
        return 0
    fi

    # Install pyenv
    debug "Installing pyenv..."
    if curl -s https://pyenv.run | bash; then
        if [[ -x "$pyenv_bin" ]]; then
            debug "Successfully installed pyenv at $pyenv_bin"
            echo "$pyenv_bin"
            return 0
        else
            error "pyenv installation failed"
            return 1
        fi
    else
        error "Failed to install pyenv"
        return 1
    fi
}

# Get available Python versions from pyenv
get_available_python_versions() {
    local pyenv_bin="$1"
    debug "Getting list of available Python versions from pyenv"

    local output
    output=$("$pyenv_bin" install --list)

    local versions=()
    while IFS= read -r line; do
        # Look for standard versions like 3.8.0, 3.9.1, etc.
        if [[ "$line" =~ ^[[:space:]]*([0-9]+\.[0-9]+\.[0-9]+)[[:space:]]*$ ]]; then
            versions+=("${BASH_REMATCH[1]}")
        fi
    done <<< "$output"

    debug "Found ${#versions[@]} available Python versions"
    echo "${versions[@]}"
}

# Find the best matching Python version
find_best_version_match() {
    local constraint="$1"
    shift
    local available_versions=("$@")

    debug "Finding best match for $constraint from ${#available_versions[@]} versions"

    # Check for exact version constraint
    if [[ "$constraint" =~ ^==([0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
        local exact_version="${BASH_REMATCH[1]}"
        debug "Found exact version constraint: $exact_version"

        # Look for the exact version
        for ver in "${available_versions[@]}"; do
            if [[ "$ver" == "$exact_version" ]]; then
                debug "Found exact match for $exact_version"
                echo "$exact_version"
                return 0
            fi
        done

        # If exact version is required but not found
        debug "No compatible versions found, but returning exact constraint: $exact_version"
        echo "$exact_version"
        return 0
    fi

    # Find all compatible versions
    local compatible_versions=()
    for ver in "${available_versions[@]}"; do
        if version_matches_constraint "$ver" "$constraint"; then
            compatible_versions+=("$ver")
        fi
    done

    if [[ ${#compatible_versions[@]} -gt 0 ]]; then
        # Sort versions and get the highest one
        # This is a simple bubble sort for versions
        local sorted_versions=("${compatible_versions[@]}")
        local n=${#sorted_versions[@]}
        for ((i=0; i<n-1; i++)); do
            for ((j=0; j<n-i-1; j++)); do
                if version_compare "${sorted_versions[j]}" "<" "${sorted_versions[j+1]}"; then
                    local temp=${sorted_versions[j]}
                    sorted_versions[j]=${sorted_versions[j+1]}
                    sorted_versions[j+1]=$temp
                fi
            done
        done

        local highest_version="${sorted_versions[0]}"
        debug "Highest compatible version: $highest_version"
        echo "$highest_version"
        return 0
    fi

    debug "No compatible versions found"
    return 1
}

# Find a matching Python version in the system or install with pyenv
find_matching() {
    local constraint="$1"
    debug "find_matching($constraint)"

    # Check system Python versions first
    local system_pythons=()
    for bin_path in /usr/bin/python* /usr/local/bin/python*; do
        if [[ -x "$bin_path" && "$bin_path" =~ python([0-9]+(\.[0-9]+)?(\.[0-9]+)?) ]]; then
            local version="${BASH_REMATCH[1]}"

            # Skip python2 versions
            if [[ "$version" == 2* ]]; then
                continue
            fi

            # Get full version if needed
            if [[ ! "$version" =~ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
                local full_version
                full_version=$("$bin_path" --version 2>&1)
                if [[ "$full_version" =~ ([0-9]+\.[0-9]+\.[0-9]+) ]]; then
                    version="${BASH_REMATCH[1]}"
                else
                    continue
                fi
            fi

            if version_matches_constraint "$version" "$constraint"; then
                system_pythons+=("$version $bin_path")
            fi
        fi
    done

    # If system Python versions found, return the highest version
    if [[ ${#system_pythons[@]} -gt 0 ]]; then
        # Simple sort to find highest version
        local highest_version=""
        local highest_path=""
        for python_info in "${system_pythons[@]}"; do
            read -r version path <<< "$python_info"
            if [[ -z "$highest_version" ]] || version_compare "$version" ">" "$highest_version"; then
                highest_version="$version"
                highest_path="$path"
            fi
        done

        debug "Found locally installed version: $highest_version at $highest_path"
        echo "$highest_path"
        return 0
    fi

    # No matching system versions, try pyenv
    local pyenv_bin
    pyenv_bin=$(ensure_pyenv_installed) || return 1

    # Get available versions from pyenv
    local available_versions_str
    available_versions_str=$(get_available_python_versions "$pyenv_bin")
    IFS=' ' read -r -a available_versions <<< "$available_versions_str"

    # Find best match from available versions
    local best_match
    best_match=$(find_best_version_match "$constraint" "${available_versions[@]}") || return 1

    # Install the version
    debug "Installing Python $best_match using pyenv"
    if "$pyenv_bin" install -s "$best_match"; then
        # Get the path to the installed Python
        local python_path
        python_path=$("$pyenv_bin" prefix "$best_match")/bin/python

        debug "Successfully installed Python at $python_path"
        echo "$python_path"
        return 0
    else
        error "Failed to install Python $best_match"
        return 1
    fi
}

# Main execution
PYPROJECT_DIR=$(dirname "$PYPROJECT_PATH")
constraint=$(get_constraint "$PYPROJECT_PATH")

if [[ -n "$constraint" ]]; then
    # Convert constraint to PEP440 format
    pep440_constraint=$(to_pep440 "$constraint")
    debug "PEP440 constraint: $pep440_constraint"

    # Check if current Python version matches
    current_version=$(current_is_good "$pep440_constraint" "$PYPROJECT_DIR")
    if [[ -n "$current_version" ]]; then
        echo "python$current_version"
        exit 0
    fi

    # Find or install a matching version
    matching=$(find_matching "$pep440_constraint")
    if [[ -n "$matching" ]]; then
        echo "$matching"
        exit 0
    else
        error "No matching Python version found for: $constraint, interpreted as $pep440_constraint"
        exit 1
    fi
else
    # No constraint found
    exit 0
fi
