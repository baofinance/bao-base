#!/usr/bin/env bash
set -euo pipefail

# Set the path to the script
SCRIPT="$1"; shift
debug "Script to run: $SCRIPT"
debug "Arguments: $*"

# Set up directories
DEPENDENCIES_DIR="$BAO_BASE_BIN_DIR/$SCRIPT"
if [ ! -d "$DEPENDENCIES_DIR" ]; then
    DEPENDENCIES_DIR="$BAO_BASE_BIN_DIR"
fi
debug "Dependencies directory: $DEPENDENCIES_DIR"

# Local directories for tools and environments
TOOLS_DIR="$BAO_BASE_DIR/.tools"
UV_DIR="$TOOLS_DIR/uv"
PYTHON_DIR="$TOOLS_DIR/python"
VENV_DIR="$DEPENDENCIES_DIR/.venv"

mkdir -p "$TOOLS_DIR" "$UV_DIR" "$PYTHON_DIR"

# Set environment variables to control UV installation paths
export UV_CACHE_DIR="$TOOLS_DIR/uv-cache"
export UV_PYTHON_PATH="$PYTHON_DIR"
mkdir -p "$UV_CACHE_DIR"

# Define virtual environment paths based on OS
if [[ "$BAO_BASE_OS" == "windows" ]]; then
    debug "Detected Windows environment"
    VENV_PYTHON_PATH="$VENV_DIR/Scripts/python.exe"
    VENV_ACTIVATE_PATH="$VENV_DIR/Scripts/activate"
    # Set UV binary name for Windows
    UV_BIN="$UV_DIR/uv.exe"
else
    VENV_PYTHON_PATH="$VENV_DIR/bin/python"
    VENV_ACTIVATE_PATH="$VENV_DIR/bin/activate"
    UV_BIN="$UV_DIR/uv"
fi
debug "Virtual environment Python path: $VENV_PYTHON_PATH"
debug "Virtual environment activation script: $VENV_ACTIVATE_PATH"

# Install uv locally
# Check if uv is already installed
if [[ ! -x "$UV_BIN" ]]; then
    debug "Installing uv to $UV_DIR"

    # Create temp directory safely across platforms
    if [[ "$BAO_BASE_OS" == "windows" ]]; then
        temp_script=$(mktemp -t uvinstall.XXXXXXXX)
        # Windows-specific temp directory handling
        temp_install_dir=$(mktemp -d -t uvinstalldir.XXXXXXXX)
        debug "Created temp dir: $temp_install_dir"
    else
        temp_script=$(mktemp)
        temp_install_dir=$(mktemp -d)
    fi

    debug "Created temp script: $temp_script"
    curl -fsSL https://astral.sh/uv/install.sh -o "$temp_script" || {
        error "Failed to download uv install script"
        exit 1
    }
    chmod +x "$temp_script"

    # Install uv to a temporary directory
    debug "Installing uv to temp directory: $temp_install_dir"
    CARGO_HOME="$temp_install_dir/cargo" RUSTUP_HOME="$temp_install_dir/rustup" \
    UV_INSTALL_DIR="$temp_install_dir/bin" NO_MODIFY_PATH=1 "$temp_script" || {
        error "Failed to run uv install script"
        exit 1
    }

    # Copy UV to final location with proper name based on OS
    if [[ "$BAO_BASE_OS" == "windows" ]]; then
        if [[ -f "$temp_install_dir/bin/uv.exe" ]]; then
            cp "$temp_install_dir/bin/uv.exe" "$UV_DIR/"
        else
            error "Failed to find uv.exe in temporary installation directory"
            ls -la "$temp_install_dir/bin" || true
            exit 1
        fi
    else
        cp "$temp_install_dir/bin/uv" "$UV_DIR/"
    fi

    rm -rf "$temp_install_dir" "$temp_script"
    debug "uv installed successfully to: $UV_BIN"
fi

debug "Using uv at: $UV_BIN"

# Check for python-requirements.in
PYTHON_REQUIREMENTS_IN="$DEPENDENCIES_DIR/python-requirements.in"
if [[ ! -f "$PYTHON_REQUIREMENTS_IN" ]]; then
    error "No python-requirements.in found at $PYTHON_REQUIREMENTS_IN"
    echo "Please create a python-requirements.in file with Python version constraints and dependencies."
    echo "Example:"
    echo "python>=3.9,<3.10 # Python (yes indeedy) version constraint"
    echo "pandas~=2.2.3"
    echo "tabulate~=0.9.0"
    exit 1
fi

debug "Found python-requirements.in file at $PYTHON_REQUIREMENTS_IN"
# Generate hash for python-requirements.in, normalising line endings if needed
calculate_hash() {
    local file="$1"
    local hash=""

    # Handle different OS hashing methods
    if [[ "${BAO_BASE_OS}" == "windows" ]]; then
        # Create a temporary file with normalized line endings
        debug "Running on Windows, converting CRLF to LF for consistent hashing"
        local temp_file=$(mktemp -t hash.XXXXXXXX)
        # Convert CRLF to LF
        if [[ "${BAO_BASE_OS_SUBTYPE}" == "powershell" ]]; then
            # Using single quotes for the PowerShell command to avoid backtick escaping issues
            powershell -Command '(Get-Content "'$file'") -replace "\r\n", "\n" | Set-Content "'$temp_file'"'

            # Generate the hash
            hash=$(powershell.exe -Command "Get-FileHash -Algorithm SHA256 -Path '$temp_file' | Select-Object -ExpandProperty Hash" | tr '[:upper:]' '[:lower:]')
        else
            # Fallback to simpler method for other Windows environments
            sed 's/\r$//' "$file" > "$temp_file"
            # Use certUtil if available
            hash=$(certUtil -hashfile "$temp_file" SHA256 2>/dev/null | grep -v "hash" | head -1 | tr -d " \t\r\n" || echo "$(date +%s)")
        fi
        rm -f "$temp_file"
    elif [[ "$BAO_BASE_OS" == "macos" ]]; then
        hash=$(shasum -a 256 "$file" | cut -d' ' -f1)
    elif [[ "$BAO_BASE_OS" == "linux" ]]; then
        hash=$(sha256sum "$file" | cut -d' ' -f1)
    else
        # Fallback with no hash - just return a timestamp to force regeneration
        debug "Unknown OS, using timestamp as hash"
        hash=$(date +%s)
    fi

    debug "Generated hash: $hash for file: $file"
    echo "$hash"
}

PYTHON_REQUIREMENTS_IN_HASH=$(calculate_hash "$PYTHON_REQUIREMENTS_IN")
debug "Generated hash for python-requirements.in: $PYTHON_REQUIREMENTS_IN_HASH"

# Check for existing .python-version and requirements.txt
PYTHON_VERSION_LOCK="$DEPENDENCIES_DIR/.python-version"
REQUIREMENTS_LOCK="$DEPENDENCIES_DIR/requirements.txt"

# Function to check if files exist and have valid hashes
validate_lock() {
    local lock_file="$1"

    # Check if both files exist
    if [[ ! -f "$lock_file" ]]; then
        echo "$lock_file does not exist, generating from python-requirements.in..."
        return 1
    fi

    local lock_hash=$(grep -E "^# HASH:[a-f0-9]{64}$" "$lock_file" | head -1 | cut -d':' -f2)
    if [[ -z "$lock_hash" ]]; then
        echo "No hash found in $lock_file, regenerating from python-requirements.in..."
        return 1
    fi

    # Check if hashes match
    if [[ "$lock_hash" != "$PYTHON_REQUIREMENTS_IN_HASH" ]]; then
        echo "$lock_file out of date (hash mismatched), regenerating from python-requirements.in..."
        debug "Hash mismatch:"
        debug "$PYTHON_REQUIREMENTS_IN: $PYTHON_REQUIREMENTS_IN_HASH"
        debug "Lock file: $lock_hash"
        return 1
    fi

    debug "Lock files exist with matching hashes"
    return 0
}

# Check if both files exist and have matching hashes
# first the python version
# as a side-effect we create the env, with the right version
if ! validate_lock "$PYTHON_VERSION_LOCK"; then
    debug "Need to regenerate lock file $PYTHON_VERSION_LOCK"

    # Extract Python version constraint from requirements file
    PYTHON_CONSTRAINT=$(grep -E "^python[>=<~!]" "$PYTHON_REQUIREMENTS_IN" | head -1)
    if [[ -z "$PYTHON_CONSTRAINT" ]]; then
        debug "No Python version constraint found in $PYTHON_REQUIREMENTS_IN, using '3'"
        PYTHON_CONSTRAINT="3"
    fi
    debug "Found Python constraint: $PYTHON_CONSTRAINT"

    # Clean up old files if they exist
    [[ -f "$PYTHON_VERSION_LOCK" ]] && rm "$PYTHON_VERSION_LOCK"
    [[ -f "$REQUIREMENTS_LOCK" ]] && rm "$REQUIREMENTS_LOCK"

    # Make sure any previous virtual environment is removed first
    if [[ -d "$VENV_DIR" ]]; then
        debug "Removing existing virtual environment at $VENV_DIR"
        rm -rf "$VENV_DIR"
    fi

    # Create virtual environment with specified Python version using uv env
    debug "Creating environment with Python constraint: $PYTHON_CONSTRAINT"
    "$UV_BIN" venv --managed-python --python "${PYTHON_CONSTRAINT}" "$VENV_DIR" || {
        error "Failed to create virtual environment with Python constraint $PYTHON_CONSTRAINT"
        exit 1
    }

    # Get the actual Python version that was installed and use it to create .python-version
    if [[ -f "$VENV_PYTHON_PATH" ]]; then
        # Extract the actual Python version from the venv
        debug "Checking Python version in virtual environment"
        ACTUAL_PYTHON_VERSION=$("$VENV_PYTHON_PATH" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}')")
        debug "Installed Python $ACTUAL_PYTHON_VERSION, creating .python-version file"

        # Create .python-version file with the actual version and hash
        {
            echo "# This file was auto-generated by run-python from constraint: $PYTHON_CONSTRAINT"
            echo "# HASH:$PYTHON_REQUIREMENTS_IN_HASH"
            echo "$ACTUAL_PYTHON_VERSION"
        } > "$PYTHON_VERSION_LOCK"
        debug "Created .python-version file with version $ACTUAL_PYTHON_VERSION and hash"
    else
        error "Failed to find Python at $VENV_PYTHON_PATH in virtual environment"
        if [[ "$BAO_BASE_OS" == "windows" ]]; then
            debug "Windows virtual environment directory structure:"
            ls -la "$VENV_DIR" || true
            ls -la "$VENV_DIR/Scripts" 2>/dev/null || true
        else
            debug "Virtual environment directory structure:"
            ls -la "$VENV_DIR" || true
            ls -la "$VENV_DIR/bin" 2>/dev/null || true
        fi
        exit 1
    fi
else
    debug "Using existing lock files with matching hash"

    # Get Python version from the .python-version file (skip comments)
    PYTHON_VERSION=$(grep -v '^#' "$PYTHON_VERSION_LOCK" | head -1 | tr -d '[:space:]')
    debug "Using Python $PYTHON_VERSION from .python-version"

    # Remove existing venv if it exists to ensure clean state
    if [[ -d "$VENV_DIR" ]]; then
        debug "Removing existing virtual environment at $VENV_DIR"
        rm -rf "$VENV_DIR"
    fi

    # Create a virtual environment with specified Python version using uv env
    debug "Creating environment with Python $PYTHON_VERSION"
    "$UV_BIN" venv --managed-python --python "$PYTHON_VERSION" "$VENV_DIR" || {
        error "Failed to create virtual environment with Python $PYTHON_VERSION"
        exit 1
    }
fi

if ! validate_lock "$REQUIREMENTS_LOCK"; then
    debug "Need to regenerate lock file $REQUIREMENTS_LOCK"
    # Generate requirements.txt
     > "$REQUIREMENTS_LOCK"
    debug "Generating $REQUIREMENTS_LOCK from $PYTHON_REQUIREMENTS_IN"
    ( # do a subprocess to avoid full path comments in the generated file
        cd "$DEPENDENCIES_DIR" || exit 1
        grep -v -E "^python[>=<~!]" "$PYTHON_REQUIREMENTS_IN" | "$UV_BIN" -q pip compile - -o "requirements.txt"
    )
    echo "# HASH:$PYTHON_REQUIREMENTS_IN_HASH" >> "$REQUIREMENTS_LOCK"
    debug "Generated $REQUIREMENTS_LOCK with hash"
fi

# Verify the Python interpreter in the venv
if [[ ! -f "$VENV_PYTHON_PATH" ]]; then
    error "Python executable not found at $VENV_PYTHON_PATH in virtual environment"
    if [[ "$BAO_BASE_OS" == "windows" ]]; then
        debug "Windows virtual environment directory structure:"
        ls -la "$VENV_DIR" || true
        ls -la "$VENV_DIR/Scripts" 2>/dev/null || true
    else
        debug "Virtual environment directory structure:"
        ls -la "$VENV_DIR" || true
        ls -la "$VENV_DIR/bin" 2>/dev/null || true
    fi
    exit 1
fi

# Make sure Python executable is executable
if [[ ! -x "$VENV_PYTHON_PATH" && "$BAO_BASE_OS" != "windows" ]]; then
    chmod +x "$VENV_PYTHON_PATH" || {
        error "Failed to make Python executable: $VENV_PYTHON_PATH"
        exit 1
    }
fi

# Install dependencies using our local uv
debug "Installing dependencies from generated requirements.txt"

# Activate the virtual environment - handle Windows differently
if [[ "$BAO_BASE_OS" == "windows" ]]; then
    # On Windows, we directly call the venv's python since activate can be tricky in bash
    debug "Running on Windows - directly using Python from venv without activation"
    PYTHON_CMD="$VENV_PYTHON_PATH"

    # Install dependencies directly with UV
    debug "Installing dependencies using UV directly on Windows"
    "$UV_BIN" pip sync --directory "$DEPENDENCIES_DIR" "$REQUIREMENTS_LOCK" || {
        error "Failed to sync dependencies from requirements.txt"
        exit 1
    }
else
    # On Unix systems, use the traditional activation approach
    source "$VENV_ACTIVATE_PATH" || {
        error "Failed to activate virtual environment at $VENV_ACTIVATE_PATH"
        exit 1
    }

    "$UV_BIN" pip sync --directory "$DEPENDENCIES_DIR" "$REQUIREMENTS_LOCK" || {
        error "Failed to sync dependencies from requirements.txt"
        deactivate 2>/dev/null || true
        exit 1
    }
    PYTHON_CMD="python"
fi

debug "Dependencies installed successfully"

# Run the target Python script or command
SCRIPT_PY="$DEPENDENCIES_DIR/$SCRIPT.py"
if [[ -f "$SCRIPT_PY" ]]; then
    debug "Running Python script: $SCRIPT_PY"
    if [[ "$BAO_BASE_OS" == "windows" ]]; then
        "$VENV_PYTHON_PATH" "$SCRIPT_PY" "$@"
    else
        $PYTHON_CMD "$SCRIPT_PY" "$@"
    fi
else
    # Check if the script exists as a system command
    if command -v "$SCRIPT" &> /dev/null; then
        debug "Running Python command: $SCRIPT"
        # Run the command
        "$SCRIPT" "$@"
    else
        error "Python script '$SCRIPT_PY' not found and command '$SCRIPT' not found in PATH"
        exit 1
    fi
fi

# Deactivate the virtual environment (not needed on Windows when we didn't activate)
if [[ "$BAO_BASE_OS" != "windows" ]]; then
    deactivate 2>/dev/null || true
fi
