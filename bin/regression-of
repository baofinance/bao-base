#!/usr/bin/env bash
set -euo pipefail

mkdir -p ./regression
REGRESSION_TYPE="$1"
shift
REGRESSION_FILE="regression/${REGRESSION_TYPE}.txt"
EXTRACTED_FILE="regression/${REGRESSION_TYPE}.txt.log" # .log is likely to be gitignored
GENERATED_LOG="regression/${REGRESSION_TYPE}.log"
info1 "generating regression for ${REGRESSION_TYPE}..."
# truncate -s 0 "${REGRESSION_FILE}" # empty the existing file

# generate the output
# do this to keep the colour on the console:
# tee >(sed 's/\x1b\[[0-9;]*m//g' > logfile.log)
# shellcheck disable=SC2154 # we don't need to check if the variable is set
. "${BAO_BASE_DIR}/run" "${REGRESSION_TYPE}" "$@" | tee "${GENERATED_LOG}"
run_status=${PIPESTATUS[0]}
debug "generating ${REGRESSION_TYPE} file complete."

if [[ "$run_status" -ne 0 ]]; then
  error "${REGRESSION_TYPE} failed (exit code ${run_status}). Fix the failing tests before running regression."
fi

# process it using the filter
# shellcheck disable=SC2154 # we don't need to check if the variable is set
EXTRACT_SCRIPT="${BAO_BASE_BIN_DIR}/extract-${REGRESSION_TYPE}.py"
if [[ -x "$EXTRACT_SCRIPT" ]]; then
  debug "calling run-python extract-${REGRESSION_TYPE} to process ${GENERATED_LOG} > ${EXTRACTED_FILE}"
  . "${BAO_BASE_BIN_DIR}/run-python" "extract-${REGRESSION_TYPE}" <"${GENERATED_LOG}" >"${EXTRACTED_FILE}"
else
  debug "$EXTRACT_SCRIPT not found, copying ${GENERATED_LOG} to ${EXTRACTED_FILE}"
  cp "${GENERATED_LOG}" "${EXTRACTED_FILE}"
fi

# Merge the fresh extract against the committed baseline and fail (so it must be committed) if the
# regression file changed. A type WITH a merge script (compare-<type>.py) gets the tolerance + ratchet;
# any other type falls back to "any difference is a change".
info1 "checking ${REGRESSION_TYPE} against ${REGRESSION_FILE}..."
debug "$(git status)"
COMPARE_SCRIPT="${BAO_BASE_BIN_DIR}/compare-${REGRESSION_TYPE}.py"

if [[ -f "$COMPARE_SCRIPT" ]]; then
  # compare-<type>.py: (committed, fresh) -> merged on stdout; exit 0 = held, 1 = changed, >1 = real error.
  # Run it under the bin uv venv (created by the extract step above) rather than run-python, which would
  # collapse the merge's "exit 1 = changed" into a generic failure.
  VENV_PYTHON="${DEPENDENCIES_DIR:-${BAO_BASE_BIN_DIR}}/.venv/bin/python3"
  report="$(mktemp)"
  merged="$(mktemp)"
  merge_status=0
  "${VENV_PYTHON}" "${COMPARE_SCRIPT}" <(git show HEAD:"${REGRESSION_FILE}" 2>/dev/null) "${EXTRACTED_FILE}" \
    >"${merged}" 2>"${report}" || merge_status=$?
  rm -f "${EXTRACTED_FILE}"

  if [[ "${merge_status}" -gt 1 ]]; then
    cat "${report}" >&2
    rm -f "${merged}" "${report}"
    error "compare-${REGRESSION_TYPE} failed (exit ${merge_status}). Fix the merge before running regression."
  fi

  # Write the merged result (only breached rows differ from the committed baseline).
  mv "${merged}" "${REGRESSION_FILE}"
  if [[ "${merge_status}" -eq 1 ]]; then
    changes="$(cat "${report}")"
    rm -f "${report}"
    error "The regression file ${REGRESSION_FILE} changed:"$'\n'"${changes}"$'\n'$'\n'"Review and commit ${REGRESSION_FILE} if the change is expected, or fix the cause."$'\n'
  fi
  rm -f "${report}"
  log "No changes detected in ${REGRESSION_FILE}"
else
  # No merge script for this type: any difference from the committed baseline is a change.
  if git diff --quiet --no-index <(git show HEAD:"${REGRESSION_FILE}" 2>/dev/null) "${EXTRACTED_FILE}"; then
    rm -f "${EXTRACTED_FILE}"
    git restore --worktree "${REGRESSION_FILE}" 2>/dev/null || :
    log "No changes detected in ${REGRESSION_FILE}"
  else
    changes="$(GIT_PAGER="" git diff --minimal --color --no-index <(git show HEAD:"${REGRESSION_FILE}" 2>/dev/null) "${EXTRACTED_FILE}" 2>&1 | tail -n +5)"
    mv "${EXTRACTED_FILE}" "${REGRESSION_FILE}"
    error "The regression file ${REGRESSION_FILE} changed:"$'\n'"${changes}"$'\n'$'\n'"Either commit the changes if they are expected or fix the cause."$'\n'
  fi
fi
