#!/usr/bin/env bash
set -e
set -o pipefail

[[ "${BAO_BASE_VERBOSITY}" -gt 0 ]] && set -x
# separate build output & cache
FOUNDRY_OUT=out/_gas
export FOUNDRY_CACHE_PATH=cache/_gas

# temp deployment scripts dir
mkdir -p tmp
export BAO_DEPLOYMENT_LOGS_ROOT=$(mktemp -d -p tmp)
trap 'rm -rf "${BAO_DEPLOYMENT_LOGS_ROOT}"' EXIT

status=0
forge test --out ${FOUNDRY_OUT} --nmp 'script/**/*.t.sol' --isolate --gas-report --fuzz-seed 1 --fuzz-runs 64 "$@" || status=$?
{ set +x; } 2>/dev/null
# make forge's exit status the script's return value: the set +x above would otherwise mask it,
# and run sources this script under `|| exit_code=$?` which suppresses set -e
( exit "$status" )
