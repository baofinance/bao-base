#!/usr/bin/env bash
set -euo pipefail

SCRIPT_ARGS=("$@")

# Parse .validate-ignore: each non-comment non-blank line is "check file".
# Supported checks: naming, pragma, storage, upgrades, bare-imports, relative-imports.
VALID_CHECKS=(naming pragma storage upgrades bare-imports relative-imports)
declare -A validate_ignores=()
_ignore_parse_failed=0
if [[ -f .validate-ignore ]]; then
  _lineno=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    ((_lineno++)) || true
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue
    read -r _check _file <<< "$line"
    _valid=0
    for _kw in "${VALID_CHECKS[@]}"; do
      [[ "$_check" == "$_kw" ]] && _valid=1 && break
    done
    if [[ $_valid -eq 0 ]]; then
      echo ".validate-ignore:${_lineno}: unknown check '${_check}' (valid: ${VALID_CHECKS[*]})" >&2
      _ignore_parse_failed=1
    fi
    if [[ ! -e "$_file" ]]; then
      echo ".validate-ignore:${_lineno}: file does not exist: '${_file}'" >&2
      _ignore_parse_failed=1
    fi
    validate_ignores["$_check $_file"]=1
  done <.validate-ignore
fi
if [[ $_ignore_parse_failed -ne 0 ]]; then
  echo "ERROR: .validate-ignore has errors — fix them before continuing" >&2
  exit 1
fi
is_ignored() { [[ -v validate_ignores["$1 $2"] ]]; }

# # Report current shell and bash version/path (works in Bash 3.2+)
# if [ -n "${BASH_VERSION:-}" ]; then
#   # Running under bash
#   echo "Bash in use: ${BASH_VERSION} (path: ${BASH:-unknown})" >&2
#   # Optional: check for >= 5.2
#   major=${BASH_VERSINFO[0]:-0}
#   minor=${BASH_VERSINFO[1]:-0}
#   if { [ "$major" -gt 5 ] || { [ "$major" -eq 5 ] && [ "$minor" -ge 2 ]; }; }; then
#     echo "Bash meets minimum 5.2 requirement" >&2
#   else
#     echo "Bash is below 5.2; PATH/runner may point to older bash" >&2
#   fi
# else
#   # Not running under bash (e.g., sh); show process and default bash
#   shell_name=$(ps -p $$ -o comm= 2>/dev/null || echo "${SHELL:-unknown}")
#   echo "Not running under bash (current shell: ${shell_name})" >&2
#   echo "Default bash in PATH: $(command -v bash 2>/dev/null || echo 'not found')" >&2
#   echo "Default bash version: $(bash --version 2>/dev/null | head -n1 || echo 'unknown')" >&2
# fi

# separate build output & cache
FOUNDRY_OUT="out/_validate"
export FOUNDRY_CACHE_PATH=cache/_validate

# clean everything, then create necessary directories
rm -rf $FOUNDRY_OUT
BUILD_INFO_DIR="$FOUNDRY_OUT/build-info"
mkdir -p "${BUILD_INFO_DIR}"

# build again with build-info this time, so we force
forge build --out ${FOUNDRY_OUT} --build-info --build-info-path "${BUILD_INFO_DIR}" --extra-output storageLayout --skip "**/*.vy" --skip "**/*.t.sol" --skip "**/*.s.sol" --force src
echo
echo "running OpenZeppelin upgrades-core validate..."
echo "-------------------------------------------"
echo

validate_upgrades() {
  npx @openzeppelin/upgrades-core validate "${BUILD_INFO_DIR}" \
    --exclude "lib/**" --exclude "script/**" --exclude "test/**" \
    "${SCRIPT_ARGS[@]}"
}

validate_upgrades || error "OpenZeppelin upgrades-core validate failed"

# ──────────────────────────────────────────────────────────────────────────────────────────────
# check that every deployable versioned (_v2+) upgradeable contract declares an upgrade reference
# to its predecessor (@custom:oz-upgrades-from). Without it OZ validates the contract in ISOLATION
# and never checks its storage layout is compatible with the deployed previous version — a silent
# gap (e.g. a re-ordered/inserted namespaced field would ship unverified). OZ appends "(upgrades
# from <ref>)" to a contract's line exactly when the annotation is present, so we read that back.
# ──────────────────────────────────────────────────────────────────────────────────────────────
echo
echo "checking version upgrade references..."
echo "--------------------------------------"
echo
version_ref_failed=0
while IFS= read -r vline; do
  # the validated contract's name is the first "<path>.sol:<Name>" token on the line
  vname="$(printf '%s' "$vline" | grep -oE '\.sol:[A-Za-z_][A-Za-z0-9_]*' | head -1 | sed 's/.*\.sol://')"
  [[ -z "$vname" ]] && continue
  if [[ "$vname" =~ ^(.+)_v([0-9]+)$ ]]; then
    vbase="${BASH_REMATCH[1]}"
    vver="${BASH_REMATCH[2]}"
    if [[ "$vver" -ge 2 ]]; then
      if [[ "$vline" != *"(upgrades from"* ]]; then
        printf '\033[31m ✘  %s: no @custom:oz-upgrades-from reference — its storage layout is NOT validated against the deployed predecessor\033[0m\n' "$vname"
        version_ref_failed=1
      elif [[ "$vline" != *":${vbase}_v"* ]]; then
        printf '\033[31m ✘  %s: @custom:oz-upgrades-from references a non-%s_v* contract\033[0m\n' "$vname" "$vbase"
        version_ref_failed=1
      else
        # the referenced predecessor is the second "<path>.sol:<Name>" token (inside "(upgrades from …)")
        vref="$(printf '%s' "$vline" | grep -oE '\.sol:[A-Za-z_][A-Za-z0-9_]*' | tail -1 | sed 's/.*\.sol://')"
        printf ' ✔  %s upgrades from %s\n' "$vname" "$vref"
      fi
    fi
  fi
done < <(validate_upgrades 2>/dev/null || true)
if [[ "$version_ref_failed" -ne 0 ]]; then
  error "versioned (_v2+) contracts must declare @custom:oz-upgrades-from their predecessor"
fi
echo
echo "SUCCESS: (all versioned upgradeable contracts reference a predecessor)"

# check for root storage access
echo
echo "checking namespace-only storage policy..."
echo "--------------------------------------"
echo
contracts=$(validate_upgrades | grep -o -E '[^[:space:]]+.sol:[A-Za-z_][A-Za-z0-9_]*')

# Allowed storage slot: OpenZeppelin Initializable (ERC-7201)
# ALLOWED_OZ_INIT_SLOT=$(cast index-erc7201 openzeppelin.storage.Initializable)
ALLOWED_OZ_INIT_SLOT="f0c57e16840df040f15088dc2f81fe391c3923bec73e23a9662efc9c229c6a00"
# Solady UpgradeableBeacon implementation slot (assembly-only; not in forge storage-layout)
# _UPGRADEABLE_BEACON_IMPLEMENTATION_SLOT = 0x911c5a209f08d5ec5e
BEACON_IMPL_SLOT="911c5a209f08d5ec5e"

failed=0
for contract in ${contracts}; do
  this_failed=0
  # skip libraries
  if [[ "$contract" == "lib/"* ]]; then
    continue
  fi
  # special case for Stem
  if [[ "$contract" == *"Stem"*".sol:"*"Stem"* ]]; then
    continue
  fi

  ################################################################
  # check for storage slots not in a namespace (i.e. root slots)
  ################################################################
  root_slots=$(forge inspect --out ${FOUNDRY_OUT} --json $contract storage-layout | jq '.storage | length')
  if is_ignored "storage" "${contract%%:*}"; then
    if [[ "${root_slots}" != "" && "${root_slots}" -eq 0 ]]; then
      printf '\033[31m ✘  stale .validate-ignore entry: storage "%s" — check passes, remove from .validate-ignore\033[0m\n' "${contract%%:*}"
      this_failed=1
    else
      printf '\033[2m ⚠  %s: storage check ignored via .validate-ignore\033[0m\n' "${contract}"
    fi
  else
    if [[ "${root_slots}" != "" && "${root_slots}" -gt 0 ]]; then
      echo "ERROR: Root slots for ${contract}: ${root_slots}\n$(forge inspect $contract storage-layout)"
      this_failed=1
    fi
  fi

  ################################################################
  # check for constructor initialised storage
  # - Must SSTORE exactly once, to OZ Initializable slot
  # - No second SSTORE allowed (any other constructor write is disallowed)
  ################################################################

  init=$(forge inspect --out ${FOUNDRY_OUT} "$contract" bytecode | tr -d '\n')
  runtime=$(forge inspect --out ${FOUNDRY_OUT} "$contract" deployedBytecode | tr -d '\n')

  # Auto-detect beacon contracts: runtime contains the Solady UpgradeableBeacon implementation
  # slot. Beacons are not UUPS proxies — their constructor writes to their own slot, not to
  # the OZ Initializable ERC-7201 slot.
  is_beacon=0
  if echo "$runtime" | grep -q "${BEACON_IMPL_SLOT}"; then
    is_beacon=1
  fi

  if is_ignored "upgrades" "${contract%%:*}"; then
    if [ "$is_beacon" -eq 1 ]; then
      printf '\033[31m ✘  stale .validate-ignore entry: upgrades "%s" — beacon auto-detected, remove from .validate-ignore\033[0m\n' "${contract%%:*}"
      this_failed=1
    else
      printf '\033[2m ⚠  %s: upgrades check ignored via .validate-ignore\033[0m\n' "${contract}"
    fi
  else

    # Mandatory: contracts must have constructor code
    if [ "$init" = "0x" ] || [ "$runtime" = "0x" ]; then
      echo "ERROR: Constructor does not call _disableInitializers(); (no creation/runtime bytecode) in $contract"
      this_failed=1
    else
      # For UUPS impls: check OZ Initializable slot in FULL creation bytecode before trimming.
      # The slot may appear in the immutable data section appended after the runtime.
      has_init_slot=0
      if [ "$is_beacon" -eq 0 ] && echo "$init" | grep -q "${ALLOWED_OZ_INIT_SLOT}"; then
        has_init_slot=1
      fi

      # Isolate constructor (init) by trimming runtime tail
      # pos=$(echo -n "$init" | grep -aob -- "${runtime#0x}" | tail -n1 | cut -d: -f1 || true) # OOM on macos
      pos=$(node -e "const a=(process.argv[1]||'').toLowerCase(); const b=(process.argv[2]||'').replace(/^0x/,'').toLowerCase(); const i=a.lastIndexOf(b); if(i>=0) process.stdout.write(String(i));" "$init" "$runtime" 2>/dev/null || true)
      if [ -n "$pos" ]; then
        init="${init:0:$pos}"
      else
        echo "WARNING: Couldn't locate runtime inside creation for $contract; scanning full creation code"
      fi

      # Count SSTOREs in constructor
      disasm=$(cast disassemble "$init")
      sstore_count=$(echo "$disasm" | grep -ci '\bSSTORE\b' || true)
      sload_count=$(echo "$disasm" | grep -ci '\bSLOAD\b' || true)

      if [ "$is_beacon" -eq 1 ]; then
        # Beacon: constructor must write exactly once (to the implementation slot).
        # No OZ Initializable slot required.
        if [ "${sstore_count:-0}" -eq 0 ]; then
          echo "ERROR: Beacon constructor does not write implementation slot (no SSTORE) in $contract"
          this_failed=1
        elif [ "${sstore_count:-0}" -gt 1 ]; then
          echo "ERROR: Beacon constructor performs multiple SSTOREs in $contract"
          this_failed=1
        fi
      else
        # UUPS proxy implementation: must SSTORE exactly once, to the OZ Initializable slot.
        if [ "${sstore_count:-0}" -eq 0 ]; then
          echo "ERROR: Constructor does not call _disableInitializers() (no SSTORE) in $contract"
          this_failed=1
        elif [ "${sstore_count:-0}" -gt 1 ]; then
          echo "ERROR: Constructor performs multiple SSTOREs in $contract (only Initializable write allowed)"
          this_failed=1
        fi
        if [ "$has_init_slot" -eq 0 ]; then
          echo "ERROR: Constructor does not reference Initializable slot (erc7201) in $contract"
          this_failed=1
        fi
      fi
    fi
  fi

  if [[ $this_failed -ne 0 ]]; then
    failed=1
    echo " ✘  ${contract}"
  else
    echo " ✔  ${contract}"
  fi
  echo ""
done
if [[ $failed -ne 0 ]]; then
  echo "ERROR: some contracts have root storage or constructor-initialized storage"
  return 1
fi
echo "SUCCESS: (no contracts have root storage or constructor-initialized storage)"

# ================================================================
# Source file naming and pragma checks
# ================================================================
echo
echo "checking source file conventions..."
echo "------------------------------------"
echo

src_failed=0
while IFS= read -r -d '' file; do
  basename=$(basename "$file" .sol)

  # Extract the contract or library name (first declaration)
  contract_name=$(grep -oE '^\s*(abstract\s+)?(contract|library)\s+\w+' "$file" | grep -oE '\w+$' | head -1)
  if [[ -z "$contract_name" ]]; then
    # No contract or library declaration (interface-only file) — skip
    continue
  fi

  # Check: filename must match contract/library name
  if is_ignored "naming" "$file"; then
    if [[ "$basename" == "$contract_name" ]]; then
      printf '\033[31m ✘  stale .validate-ignore entry: naming "%s" — check passes, remove from .validate-ignore\033[0m\n' "$file"
      src_failed=1
    else
      printf '\033[2m ⚠  %s: naming check ignored via .validate-ignore (filename '\''%s'\'', contract '\''%s'\'')\033[0m\n' "$file" "$basename" "$contract_name"
    fi
  elif [[ "$basename" != "$contract_name" ]]; then
    echo " ✘  $file: filename '$basename' does not match '$contract_name'"
    src_failed=1
  fi

  # Check: deployable code must pin pragma (not use a range)
  # Deployable = concrete contract, or library with public/external functions
  is_abstract=$(grep -cE '^\s*abstract\s+contract\s' "$file" || true)
  is_library=$(grep -cE '^\s*library\s' "$file" || true)
  is_deployable_library=0
  if [[ "$is_library" -gt 0 ]]; then
    # Library is deployable only if it has public or external functions
    has_external=$(grep -cE '^\s+function\s+\w+.*(public|external)' "$file" || true)
    if [[ "$has_external" -gt 0 ]]; then
      is_deployable_library=1
    fi
  fi
  if [[ ("$is_abstract" -eq 0 && "$is_library" -eq 0) || "$is_deployable_library" -gt 0 ]]; then
    # Concrete contract or deployable library — pragma should be pinned
    pragma=$(grep -oE 'pragma solidity\s+[^;]+' "$file" | sed 's/pragma solidity[[:space:]]*//' || true)
    if is_ignored "pragma" "$file"; then
      if ! echo "$pragma" | grep -qE '[<>]'; then
        printf '\033[31m ✘  stale .validate-ignore entry: pragma "%s" — check passes, remove from .validate-ignore\033[0m\n' "$file"
        src_failed=1
      else
        printf '\033[2m ⚠  %s: pragma check ignored via .validate-ignore (pragma '\''%s'\'')\033[0m\n' "$file" "$pragma"
      fi
    elif echo "$pragma" | grep -qE '[<>]'; then
      echo " ✘  $file: deployable '$contract_name' uses version range '$pragma' — should pin (e.g. 0.8.30)"
      src_failed=1
    fi
  fi
done < <(find src -name '*.sol' -print0)

if [[ $src_failed -ne 0 ]]; then
  echo
  echo "ERROR: some source files have naming or pragma issues"
  return 1
fi
echo "SUCCESS: (all source files follow naming and pragma conventions)"

# ================================================================
# Import path checks — bare imports (src/test/script prefix)
# ================================================================
echo
echo "checking for bare imports..."
echo "----------------------------"
echo

bare_failed=0
while IFS= read -r -d '' file; do
  if is_ignored "bare-imports" "$file"; then
    printf '\033[2m ⚠  %s: bare-imports check ignored via .validate-ignore\033[0m\n' "$file"
    continue
  fi
  bad_lines=$(grep -nE 'import[[:space:]].*"(src|test|script)/[^"]*"' "$file" || true)
  if [[ -n "$bad_lines" ]]; then
    while IFS= read -r bad; do
      echo " ✘  $file: bare import: $bad"
    done <<< "$bad_lines"
    bare_failed=1
  fi
done < <(find src script test -name '*.sol' -print0 2>/dev/null)

if [[ $bare_failed -ne 0 ]]; then
  echo
  echo "ERROR: bare imports found — use remapped prefixes (@bao/, @bao-test/, @bao-script/, etc.)"
  return 1
fi
echo "SUCCESS: (no bare imports)"

# ================================================================
# Import path checks — relative imports (. or .. prefix)
# ================================================================
echo
echo "checking for relative imports..."
echo "--------------------------------"
echo

relative_failed=0
while IFS= read -r -d '' file; do
  if is_ignored "relative-imports" "$file"; then
    printf '\033[2m ⚠  %s: relative-imports check ignored via .validate-ignore\033[0m\n' "$file"
    continue
  fi
  bad_lines=$(grep -nE 'import[[:space:]].*"(\.\.|\.)/[^"]*"' "$file" || true)
  if [[ -n "$bad_lines" ]]; then
    while IFS= read -r bad; do
      echo " ✘  $file: relative import: $bad"
    done <<< "$bad_lines"
    relative_failed=1
  fi
done < <(find src script test -name '*.sol' -print0 2>/dev/null)

if [[ $relative_failed -ne 0 ]]; then
  echo
  echo "ERROR: relative imports found — use remapped prefixes (@bao/, @bao-test/, @bao-script/, etc.)"
  return 1
fi
echo "SUCCESS: (no relative imports)"
