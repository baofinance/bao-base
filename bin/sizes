#!/usr/bin/env bash
set -e
set -o pipefail

# put the output in a different directory, so as not to clash with the normal forge build output
FOUNDRY_OUT="out/_sizes"
export FOUNDRY_CACHE_PATH=cache/_sizes
mkdir -p "${FOUNDRY_OUT}"

# forge clean, forcing the build as we don't trust the cache
debug "BAO_BASE_VERBOSITY=${BAO_BASE_VERBOSITY}."
[[ "${BAO_BASE_VERBOSITY}" -gt 0 ]] && set -x
status=0
forge build --sizes --out ${FOUNDRY_OUT} --force src test/_sizes script || status=$?
{ set +x; } 2>/dev/null
# make forge's exit status the script's return value: the set +x above would otherwise mask it,
# and run sources this script under `|| exit_code=$?` which suppresses set -e
( exit "$status" )
